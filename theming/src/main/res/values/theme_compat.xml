<resources>

    // A P P L I C A T I O N

    <style name="MyBaseThemeCompat" parent="Theme.MaterialComponents.DayNight.NoActionBar.Bridge">

       <!-- theme UI controls action bar -->
       <item name="actionBarTheme">@style/MyActionBarThemeCompat</item>
       <item name="android:actionBarStyle">@style/MyActionBarStyleCompat</item>

       <!-- theme UI controls pop ups -->
       <item name="actionBarPopupTheme">@style/MyActionBarPopupThemeCompat</item>

       <!-- actionbar spinner -->
       <item name="android:dropDownListViewStyle">@style/MySpinnerDropDownStyleCompat</item>
       <item name="android:spinnerStyle">@style/MySpinnerStyleCompat</item>
       <item name="spinnerStyle">@style/MySpinnerStyleCompat</item>

       <!-- preference -->
<!--       <item name="preferenceTheme">@style/MyPreferenceTheme</item>-->

       <!-- alert dialog -->
       <item name="alertDialogTheme">@style/MyAlertDialogThemeCompat</item>

        <!-- transparent statusbar and navigation bar -->
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>

    </style>

    <style name="MyAppThemeCompat" parent="MyBaseThemeCompat" />

    // T R E E B O L I C A P P L I C A T I O N

    <style name="MyTreebolicBaseThemeCompat" parent="MyAppThemeCompat">

        <!-- treebolic toolbar -->
        <item name="treebolic_toolbar_background">?attr/colorPrimary</item>
        <item name="treebolic_toolbar_foreground_icon">?attr/colorOnPrimary</item>

        <!-- treebolic status bar -->
        <item name="treebolic_statusbar_background">?attr/colorPrimary</item>
        <item name="treebolic_statusbar_foreground">?attr/colorOnPrimary</item>
        <item name="treebolic_statusbar_foreground_enhanced">?attr/colorOnPrimaryFixed</item>
        <item name="treebolic_statusbar_foreground_icon">?attr/colorOnPrimary</item>

        <!-- treebolic dialog -->
        <item name="treebolic_dialog_background">?attr/colorPrimary</item>
        <item name="treebolic_dialog_foreground">?attr/colorOnPrimary</item>
        <item name="treebolic_dialog_foreground_enhanced">?attr/colorOnPrimaryFixed</item>
        <item name="treebolic_dialog_foreground_icon">?attr/colorOnPrimary</item>

        <!-- treebolic split bar -->
        <item name="treebolic_splitbar_color">?attr/colorPrimaryDark</item>
        <item name="treebolic_splitbar_drag_color">?attr/colorAccent</item>

        <!-- treebolic splash -->
        <item name="treebolic_splash_background">?attr/colorPrimary</item>
        <item name="treebolic_splash_foreground">?attr/colorOnPrimary</item>
        <item name="treebolic_splash_progress">?attr/colorSecondary</item>

        <!-- treebolic search settings -->
        <item name="treebolic_search_settings_background">?attr/colorPrimary</item>
        <item name="treebolic_search_settings_foreground">?attr/colorOnPrimary</item>

    </style>

    <style name="MyTreebolicThemeCompat" parent="MyTreebolicBaseThemeCompat" />

</resources>