<resources>

	<!-- T H E M E   O V E R L A Y S -->

	<!-- ActionBar -->
	<style name="MyActionBarThemeCompat" parent="ThemeOverlay.AppCompat.DayNight.ActionBar">
		<item name="android:background">@null</item> <!-- menu overflow, search view, title, subtitle backgrounds -->
		<item name="android:textColorPrimary">?attr/actionbar_title_fore_color</item> <!-- search view foreground -->
		<item name="android:textColorSecondary">?attr/actionbar_subtitle_fore_color</item> <!-- subtitle -->
		<item name="colorControlNormal">?attr/actionbar_fore_color</item> <!-- pictograms (menu overflow, search magnifying glass, navigation) -->
		<item name="searchViewStyle">@style/MyActionBarSearchViewCompat</item>
	</style>

	<!-- ActionBar Popup -->
	<style name="MyActionBarPopupThemeCompat" parent="ThemeOverlay.AppCompat.DayNight">
		<item name="android:background">?attr/actionbar_color</item> <!-- submenu background -->
		<item name="android:textColorPrimary">?attr/actionbar_fore_color</item>item> <!-- item foreground -->
		<item name="android:textColorSecondary">?attr/actionbar_secondary_fore_color</item> <!-- submenu item foreground -->
	</style>

	<!-- AlertDialog -->
	<style name="MyAlertDialogThemeCompat" parent="ThemeOverlay.AppCompat.Dialog.Alert">
		<item name="buttonBarNegativeButtonStyle">@style/MyNegativeButtonStyleCompat</item>
		<item name="buttonBarPositiveButtonStyle">@style/MyPositiveButtonStyleCompat</item>
		<item name="buttonBarNeutralButtonStyle">@style/MyNeutralButtonStyleCompat</item>
	</style>

	<!-- Preference -->
	<style name="MyPreferenceThemeCompat" parent="PreferenceThemeOverlay" />

	<!-- W I D G E T   S T Y L E S -->

	<!-- Action bar -->
	<style name="MyActionBarStyleCompat" parent="Widget.AppCompat.ActionBar">
		<item name="android:background">?attr/actionbar_color</item> <!-- whole actionbar background -->
	</style>

	<!-- Action bar spinner -->
	<style name="MySpinnerStyleCompat" parent="Widget.AppCompat.Spinner">
		<item name="android:background">@drawable/bg_spinner</item>-->
		<item name="android:dropDownSelector">?attr/listChoiceBackgroundIndicator</item>
	</style>

	<!-- Action bar spinner dropdown list -->
	<style name="MySpinnerDropDownStyleCompat" parent="Widget.AppCompat.ListView.DropDown">
		<item name="android:background">?attr/actionbar_color</item>
		<item name="android:dropDownSelector">?attr/listChoiceBackgroundIndicator</item>
	</style>

	<!-- Action bar search view -->
	<style name="MyActionBarSearchViewCompat" parent="Widget.AppCompat.SearchView.ActionBar">
		<item name="queryBackground">?attr/actionbar_color</item>
		<item name="submitBackground">?attr/actionbar_fore_color</item>
	</style>

	<!-- Toolbar -->
	<style name="MyToolbarStyleCompat" />

	<!-- Dialog buttons no -->
	<style name="MyNegativeButtonStyleCompat" parent="Widget.AppCompat.Button.Borderless.Colored">
		<item name="android:textColor">?attr/colorAccent</item>
		<item name="android:textAllCaps">true</item>
	</style>

	<!-- Dialog button yes -->
	<style name="MyPositiveButtonStyleCompat" parent="Widget.AppCompat.Button.Borderless.Colored">
		<item name="android:textColor">?attr/colorAccent</item>
		<item name="android:textAllCaps">true</item>
	</style>

	<!-- Dialog button neutral -->
	<style name="MyNeutralButtonStyleCompat" parent="Widget.AppCompat.Button.Borderless.Colored">
		<item name="android:textColor">?attr/colorAccent</item>
		<item name="android:textAllCaps">true</item>
	</style>

</resources>