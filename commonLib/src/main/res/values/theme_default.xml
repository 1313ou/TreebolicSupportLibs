<resources>

    <!-- Default application theme. -->
    <style name="MyTreebolicDefaultTheme" parent="MyTreebolicTheme">
        <!-- darkness -->
        <item name="isDark">true</item>

        <!-- extras color attrs -->
        <item name="colorForePrimary">@color/default_primaryForeColor</item>
        <item name="colorForeSecondary">@color/default_secondaryForeColor</item>
        <item name="colorForeTertiary">@color/default_tertiaryForeColor</item>

        <!--treebolic UI color attr -->
        <item name="actionbar_color">@color/default_primaryColor</item>
        <item name="actionbar_fore_color">@color/default_primaryForeColor</item>
        <item name="actionbar_secondary_fore_color">@color/default_secondaryForeColor</item>
        <item name="actionbar_title_fore_color">@color/default_primaryForeColor</item>
        <item name="actionbar_subtitle_fore_color">@color/default_secondaryForeColor</item>

        <!-- treebolic widget colors -->
        <item name="treebolic_back_color">#adc1cc</item>
        <item name="treebolic_tree_edge_color">#cccccc</item>
        <item name="treebolic_root_background_color">#0000ff</item>
        <item name="treebolic_root_foreground_color">#ffffff</item>
        <item name="treebolic_node_background_color">#ffffff</item>
        <item name="treebolic_node_foreground_color">#000000</item>

    </style>

</resources>