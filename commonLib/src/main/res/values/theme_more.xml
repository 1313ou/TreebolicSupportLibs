<resources>

	<!-- T H E M E   O V E R L A Y S -->

	<!-- ActionBar -->

	<!-- ActionBar Popup -->
	<style name="MyActionBarPopupTheme" parent="ThemeOverlay.AppCompat.DayNight">
		<item name="android:background">?attr/actionbar_color</item> <!-- submenu background -->
		<item name="android:textColorPrimary">?attr/actionbar_fore_color</item>item> <!-- item foreground -->
		<item name="android:textColorSecondary">?attr/actionbar_secondary_fore_color</item> <!-- submenu item foreground -->
	</style>

	<!-- AlertDialog -->
	<style name="MyAlertDialogTheme" parent="ThemeOverlay.AppCompat.Dialog.Alert">
		<item name="buttonBarNegativeButtonStyle">@style/MyNegativeButtonStyle</item>
		<item name="buttonBarPositiveButtonStyle">@style/MyPositiveButtonStyle</item>
		<item name="buttonBarNeutralButtonStyle">@style/MyNeutralButtonStyle</item>
	</style>

	<!-- Preference -->
	<style name="MyPreferenceTheme" parent="PreferenceThemeOverlay" />

	<!-- W I D G E T   S T Y L E S -->

	<!-- Action bar -->

	<!-- Action bar spinner -->

	<!-- Action bar spinner dropdown list -->

	<!-- Action bar search view -->

	<!-- Dialog buttons no -->
	<style name="MyNegativeButtonStyle" parent="Widget.AppCompat.Button.Borderless.Colored">
		<item name="android:textColor">?attr/colorAccent</item>
		<item name="android:textAllCaps">true</item>
	</style>

	<!-- Dialog button yes -->
	<style name="MyPositiveButtonStyle" parent="Widget.AppCompat.Button.Borderless.Colored">
		<item name="android:textColor">?attr/colorAccent</item>
		<item name="android:textAllCaps">true</item>
	</style>

	<!-- Dialog button neutral -->
	<style name="MyNeutralButtonStyle" parent="Widget.AppCompat.Button.Borderless.Colored">
		<item name="android:textColor">?attr/colorAccent</item>
		<item name="android:textAllCaps">true</item>
	</style>

	<style name="MyToolbarStyle" />

</resources>